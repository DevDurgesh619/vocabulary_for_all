# Copy to .env.local and fill in from your Supabase project (Settings -> API).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Passcode that unlocks Settings editing (admin-only). Server-side, never exposed to the browser.
ADMIN_PASSCODE=choose-a-strong-passcode

# Counsellor area: secret to claim counsellor access + service-role key for the privileged
# role change. Both are SERVER-ONLY (never sent to the browser). Get the service role key
# from Supabase -> Settings -> API.
COUNSELLOR_SECRET=choose-a-counsellor-secret
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
